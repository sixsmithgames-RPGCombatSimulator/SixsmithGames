# Sixsmith Games Website - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Blog API (for AI agent to publish posts)
# ============================================
# Generate a strong random secret: openssl rand -hex 32
BLOG_API_SECRET=blog_live_plsbjor69me
# GitHub Gist ID where dynamic posts are stored (create a gist with a posts.json file containing [])
BLOG_GIST_ID=your-gist-id-here
# GitHub Personal Access Token with gist scope (https://github.com/settings/tokens)
BLOG_GITHUB_TOKEN=ghp_your-token-here
# ============================================
# Stripe Configuration (for subscription payments)
# ============================================
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Stripe Webhook Secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Stripe Price IDs — one per plan (from Stripe Dashboard > Products)
NEXT_PUBLIC_STRIPE_PRICE_BUNDLE=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_CONTENTCRAFT=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_VCS=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_MASTERTYPING=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_FSG=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_GRAVITY=price_xxxxxxxxxxxxx

# ============================================
# Clerk Authentication
# ============================================
# Get these from https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Clerk redirect URLs (optional - defaults work for most cases)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Admin emails (comma-separated) - server-only bypass for verified Clerk primary emails
ADMIN_EMAILS=your-email@example.com

# ============================================
# Application URLs
# ============================================
# Your production domain (used for Stripe redirects)
NEXT_PUBLIC_URL=https://www.sixsmithgames.com

# ============================================
# Backend Services (Optional - for future integration)
# ============================================
# VirtualCombatSimulator backend (hosted on Railway)
NEXT_PUBLIC_VCS_API_URL=https://your-vcs-backend.railway.app

# ContentCraft backend (hosted on Railway)
NEXT_PUBLIC_CONTENTCRAFT_API_URL=https://your-contentcraft-backend.railway.app

# ============================================
# Analytics (Optional)
# ============================================
# Google Analytics ID (already hardcoded in layout.tsx)
NEXT_PUBLIC_GA_ID=G-QWPPFGCSHD

# Vercel Analytics (automatically enabled on Vercel)
# No configuration needed

# Facebook Conversions API (CAPI) - Server-side event tracking
# Get your Pixel ID from Facebook Events Manager
FACEBOOK_PIXEL_ID=your-pixel-id-here
# Generate an access token from Facebook Events Manager > Settings > Conversions API
FACEBOOK_ACCESS_TOKEN=EAAS2RGTXwykBRRK3NowxdCcQNV3KtoBmQDaZC6IxZA804FYJXgjAIoeV9rDam4YrFHAjvMwauEnjoybmgCZC6ZC7j7N1zGNhoLvkZBx7KpaRB4ZA5Fc6sw09pdZAJ7ZBO9U7adZC9pR2siApoPXduJOXYqMUa4P4BB14IgkgZBJr9AQgfb0lHOZAg71yZCT0UPZCSgskkHwZDZD

# ============================================
# Cloudinary (for screenshot hosting)
# ============================================
# Get these from https://console.cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dxz6khmew
CLOUDINARY_API_KEY=485375942971756
CLOUDINARY_API_SECRET=your_api_secret_here

# ============================================
# Development Settings
# ============================================
# Set to 'production' for production builds
NODE_ENV=development

# Server port (default: 3000)
PORT=3000
